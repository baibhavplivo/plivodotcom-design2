---
// HeroSection.astro - Dark theme hero for Build for Bharat offer page
// Matches the screenshot: dark bg, spotlight effect, motif border, logos, headline, CTA
---

<section class="relative overflow-hidden bg-[#0a0a1a] text-white">
  <!-- Motif top border -->
  <div class="absolute top-0 left-0 right-0 z-10 h-[28px] flex overflow-hidden">
    <div class="flex shrink-0">
      {Array.from({ length: 20 }).map(() => (
        <img src="/images/build-for-bharat/motif.svg" alt="" class="h-[28px] w-auto" />
      ))}
    </div>
  </div>

  <!-- Background spotlight effect -->
  <div class="absolute inset-0 z-0">
    <!-- Bright source point at top center -->
    <div class="absolute top-[24px] left-1/2 -translate-x-1/2 w-[8px] h-[8px] rounded-full"
      style="background: white; box-shadow: 0 0 20px 8px hsl(var(--background) / 0.9), 0 0 60px 20px hsl(var(--background) / 0.5), 0 0 120px 40px rgba(255,255,255,0.2);">
    </div>

    <!-- Narrow bright beam from source -->
    <div class="absolute top-[28px] left-1/2 -translate-x-1/2 w-[3px] h-[120px]"
      style="background: linear-gradient(to bottom, hsl(var(--background) / 0.8), rgba(255,255,255,0.1) 70%, transparent);">
    </div>

    <!-- Primary light cone using clip-path -->
    <div class="absolute top-[28px] left-1/2 -translate-x-1/2 w-[800px] h-[600px]"
      style="background: linear-gradient(to bottom, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 40%, transparent 80%); clip-path: polygon(50% 0%, 72% 100%, 28% 100%);">
    </div>

    <!-- Wider softer ambient cone -->
    <div class="absolute top-[28px] left-1/2 -translate-x-1/2 w-[1200px] h-[700px]"
      style="background: linear-gradient(to bottom, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.015) 50%, transparent 85%); clip-path: polygon(50% 0%, 78% 100%, 22% 100%);">
    </div>

    <!-- Radial glow on the ground / text area -->
    <div class="absolute top-[200px] left-1/2 -translate-x-1/2 w-[700px] h-[400px]"
      style="background: radial-gradient(ellipse at center, rgba(255,255,255,0.04) 0%, transparent 70%);">
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto max-w-7xl px-4 pt-20 pb-16 sm:pt-24 sm:pb-20 lg:pt-28 lg:pb-24">
    <!-- Top logos -->
    <div class="flex items-center justify-between mb-16 sm:mb-20 lg:mb-24">
      <img
        src="/images/build-for-bharat/plivo-logo.svg"
        alt="Plivo"
        class="h-6 sm:h-8 w-auto"
      />
      <img
        src="/images/build-for-bharat/ai-summit-logo.svg"
        alt="AI Impact Summit India 2026"
        class="h-10 sm:h-14 w-auto"
      />
    </div>

    <!-- Main headline area -->
    <div class="text-center max-w-4xl mx-auto">
      <!-- Main headline -->
      <h1 class="font-sora text-[2.5rem] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[5.5rem] font-medium leading-[1.05] tracking-[-0.02em] mb-6 uppercase">
        <span class="bg-gradient-to-r from-[#b8b4ff] via-[#d4d0ff] to-[#b8b4ff] bg-clip-text text-transparent">Built for Bharat</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl md:text-2xl text-gray-200 font-light mb-10 sm:mb-12">
        100% extra credits on every recharge. Feb 16-20 only
      </p>

      <!-- CTA Button -->
      <div class="mb-12 sm:mb-16">
        <a
          href="https://cx.plivo.com/pungis2"
          data-geo-cta="signup"
          class="inline-flex items-center justify-center px-10 py-4 text-lg font-semibold bg-background text-foreground rounded-lg hover:bg-muted transition-all duration-200 shadow-sm hover:shadow-xl hover:-translate-y-0.5"
        >
          Sign Up Now
        </a>
      </div>

      <!-- Description -->
      <p class="text-base sm:text-lg text-muted-foreground max-w-2xl leading-relaxed">
        Sign up during India AI Summit week and we'll match every recharge
        you make. No code. No limits. Applied automatically.
      </p>
    </div>
  </div>

  <!-- Bottom subtle fade to white for transition to light sections -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-b from-transparent to-[#0a0a1a]"></div>
</section>
