---
interface ContentSection {
  heading: string;
  paragraphs: string[];
  quote?: {
    text: string;
    attribution: string;
  };
  subPoints?: {
    title: string;
    description: string;
  }[];
}

interface Props {
  sections: ContentSection[];
}

const { sections } = Astro.props;
---

<article class="space-y-12">
  {sections.map((section) => (
    <div>
      <h2 class="font-sora text-[1.75rem] sm:text-[2rem] md:text-[2.5rem] font-normal leading-[1.25] tracking-[-0.02em] text-black mb-4">
        {section.heading}
      </h2>

      {section.paragraphs.map((p) => (
        <p class="text-base sm:text-lg text-gray-600 leading-relaxed mb-4">{p}</p>
      ))}

      {section.quote && (
        <blockquote class="border-l-4 border-black pl-6 py-2 my-8">
          <p class="text-lg text-gray-700 italic leading-relaxed">
            &ldquo;{section.quote.text}&rdquo;
          </p>
          <footer class="mt-3 text-sm text-gray-500">
            &mdash; <cite class="not-italic">{section.quote.attribution}</cite>
          </footer>
        </blockquote>
      )}

      {section.subPoints && (
        <div class="space-y-6 mt-6">
          {section.subPoints.map((point) => (
            <div>
              <h3 class="font-sora text-lg font-semibold text-black mb-2">{point.title}</h3>
              <p class="text-base sm:text-lg text-gray-600 leading-relaxed">{point.description}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  ))}
</article>
