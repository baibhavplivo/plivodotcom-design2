---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  badge = "Customer Story",
  title,
  subtitle,
  ctaText = "Watch the Story",
  ctaHref = "#video",
} = Astro.props;
---

<section class="bg-background pt-16 sm:pt-20 md:pt-24 pb-12 sm:pb-16">
  <div class="container mx-auto max-w-7xl px-4 text-center">
    {/* Badge */}
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface mb-8">
      <span class="text-[13px] font-medium text-muted-foreground uppercase tracking-wider">{badge}</span>
    </div>

    {/* Headline */}
    <h1 class="font-sora text-[2rem] sm:text-[2.5rem] md:text-[3rem] font-normal leading-[1.1] tracking-[-0.02em] text-foreground max-w-4xl mx-auto">
      {title}
    </h1>

    {/* Subtitle */}
    {subtitle && (
      <p class="text-base sm:text-lg text-muted-foreground mt-5 leading-relaxed max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}

    {/* CTA Button */}
    <a
      href={ctaHref}
      class="inline-flex items-center gap-2.5 px-7 py-3 text-base font-medium bg-foreground text-background rounded-md hover:bg-gray-800 transition-colors mt-8"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="flex-shrink-0" aria-hidden="true">
        <path d="M4 2L14 8L4 14V2Z" fill="currentColor" />
      </svg>
      {ctaText}
    </a>
  </div>
</section>
