---
// GoLiveSteps.astro - 3-step process for AI agent setup

const steps = [
  {
    number: "01",
    title: "Describe your use case",
    description: "Share what you want your agent to do. Vibe understands your intent and gets to work.",
  },
  {
    number: "02",
    title: "Let Vibe Agent build the flow",
    description: "Vibe connects the dots - setting up actions, triggers, and integrations automatically.",
  },
  {
    number: "03",
    title: "Review and launch",
    description: "Test the experience, make quick tweaks, and deploy your agent across channels with a single click.",
  },
];
---

<section class="py-12 lg:py-16 bg-white">
  <div class="container mx-auto max-w-7xl px-4">
    <div class="text-center mb-12">
      <h2 class="font-sora text-[2rem] sm:text-[2.5rem] font-normal leading-[1.25] tracking-[-0.02em] text-black">
        Go live with AI agents in minutes
      </h2>
      <p class="text-base sm:text-lg text-gray-600 mt-4 max-w-2xl mx-auto leading-relaxed">
        With Plivo's guided setup, you can build, test, and launch production-ready agents - without code or complexity.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      {steps.map((step, idx) => (
        <div class="flex flex-col">
          {/* Step number */}
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[2rem] font-semibold text-gray-300">
              {step.number}
            </span>
            <div class="h-px flex-1 bg-gray-200" />
          </div>

          {/* CSS Illustration */}
          <div class="rounded-xl border border-gray-200 bg-white p-4 mb-5 h-[210px] overflow-hidden">
            {idx === 0 && (
              <div class="space-y-3">
                {/* Prompt input mockup */}
                <div class="flex items-center gap-2 text-[10px] text-gray-400">
                  <div class="flex gap-1">
                    <div class="w-2 h-2 rounded-full bg-red-300" />
                    <div class="w-2 h-2 rounded-full bg-yellow-300" />
                    <div class="w-2 h-2 rounded-full bg-green-300" />
                  </div>
                  <span>Vibe Agent</span>
                </div>
                <div class="rounded-lg border border-gray-200 p-3 bg-gray-50">
                  <p class="text-[11px] text-gray-700 leading-relaxed">
                    "Build me a customer support agent that handles refund requests. It should ask for the order number, look it up, and process refunds automatically..."
                  </p>
                  <div class="flex items-center gap-1 mt-2">
                    <div class="w-[2px] h-3.5 bg-[#323dfe]/60 rounded-full animate-pulse" />
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <img src="/images/buddy.svg" alt="AI Agent" class="w-6 h-6" />
                  <span class="text-[10px] text-gray-500">Analyzing your requirements...</span>
                </div>
              </div>
            )}

            {idx === 1 && (
              <div class="flex flex-col items-center">
                {/* Trigger Card */}
                <div class="w-full max-w-[180px] rounded-lg bg-white border border-gray-200 shadow-sm p-2.5">
                  <span class="inline-block px-1.5 py-px rounded text-[7px] font-bold tracking-wide uppercase bg-purple-100 text-purple-600 mb-1.5">Trigger</span>
                  <div class="flex items-center gap-1.5">
                    <div class="w-5 h-5 rounded bg-purple-100 flex items-center justify-center flex-shrink-0">
                      <svg class="w-3 h-3 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                    </div>
                    <span class="text-[10px] font-medium text-gray-800">When a customer calls</span>
                  </div>
                  <div class="mt-2 space-y-1">
                    <div class="h-1 rounded-full bg-gray-100 w-full" />
                    <div class="h-1 rounded-full bg-gray-100 w-3/4" />
                  </div>
                </div>

                {/* Connector */}
                <div class="flex flex-col items-center">
                  <div class="w-px h-2 border-l border-dashed border-gray-300" />
                  <div class="w-2.5 h-2.5 rounded-full bg-gray-200 border-2 border-white shadow-sm" />
                  <div class="w-px h-2 border-l border-dashed border-gray-300" />
                </div>

                {/* Greeting Message Card */}
                <div class="w-full max-w-[180px] rounded-lg bg-white border border-blue-200 shadow-sm p-2.5">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-1.5">
                      <svg class="w-3 h-3 text-[#323dfe]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>
                      <span class="text-[10px] font-medium text-gray-800">Greeting Message</span>
                    </div>
                    <svg class="w-3 h-3 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg>
                  </div>
                  <div class="mt-2 space-y-1">
                    <div class="h-1 rounded-full bg-blue-50 w-full" />
                    <div class="h-1 rounded-full bg-blue-50 w-4/5" />
                    <div class="h-1 rounded-full bg-blue-50 w-3/5" />
                  </div>
                </div>

                {/* Add button connector */}
                <div class="flex flex-col items-center">
                  <div class="w-px h-2 border-l border-dashed border-gray-300" />
                  <div class="w-3.5 h-3.5 rounded-full border border-gray-300 bg-white flex items-center justify-center">
                    <svg class="w-2 h-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                  </div>
                </div>
              </div>
            )}

            {idx === 2 && (
              <div class="space-y-1.5">
                {/* Analysis Mode header */}
                <div class="flex items-center justify-between pb-1.5 border-b border-gray-100">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3 h-3 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5-6L16.5 15m0 0L12 10.5M16.5 15V1.5" /></svg>
                    <span class="text-[10px] font-semibold text-gray-800">Analysis Mode</span>
                    <span class="text-[8px] text-gray-400 ml-1">Total Response: 5</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <svg class="w-2.5 h-2.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" /></svg>
                    <svg class="w-2.5 h-2.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </div>
                </div>

                {/* User Message block */}
                <div class="rounded-md border border-gray-200 p-2">
                  <span class="inline-block px-1.5 py-0.5 rounded text-[7px] font-medium bg-cyan-50 text-teal-700 border border-cyan-200 mb-1">User Message</span>
                  <p class="text-[10px] text-gray-800 font-medium leading-relaxed">Hi, I placed an order last week and it still hasn't arrived. Can you help me check the status?</p>
                </div>

                {/* AI Response block */}
                <div class="rounded-md border border-gray-200 p-2 space-y-1.5">
                  <div class="flex items-center justify-between">
                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[7px] font-medium bg-amber-50 text-amber-700 border border-amber-200">
                      <svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
                      AI Response 1
                    </span>
                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[7px] font-medium bg-purple-100 text-purple-700">
                      <svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>
                      Fine Tune
                    </span>
                  </div>
                  <div class="space-y-1">
                    <div class="flex items-center gap-1.5 text-[9px]">
                      <span class="text-gray-400 w-14 flex-shrink-0">Current Node:</span>
                      <div class="flex items-center gap-1">
                        <svg class="w-2.5 h-2.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
                        <span class="text-gray-800 font-medium">Greet the customer</span>
                      </div>
                    </div>
                    <div class="flex items-start gap-1.5 text-[9px]">
                      <span class="text-gray-400 w-14 flex-shrink-0 pt-0.5">Prompt:</span>
                      <span class="text-gray-600 leading-snug">**Greeting the Customer** Alright, let's kick things off by g...</span>
                    </div>
                    <div class="flex items-center gap-1.5 text-[9px]">
                      <span class="text-gray-400 w-14 flex-shrink-0">Chosen Path:</span>
                      <span class="text-gray-500">--</span>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* Text */}
          <h3 class="font-inter text-[1.25rem] font-semibold text-black mb-2">{step.title}</h3>
          <p class="text-[1rem] text-gray-600 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    {/* CTAs */}
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/contact/sales/"
        class="inline-flex items-center justify-center px-6 py-3 text-base font-medium border border-gray-300 text-black rounded-md hover:bg-gray-50 transition-colors"
      >
        Contact Sales
      </a>
      <a
        href="https://cx.plivo.com/pungis2"
        class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-black text-white rounded-md hover:bg-gray-800 transition-colors"
      >
        Get Started Now
      </a>
    </div>
  </div>
</section>
