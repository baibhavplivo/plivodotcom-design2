---
// AIFeatureCards.astro - 2-column feature cards with illustrations from WA overview
---

<section class="py-12 lg:py-16 bg-white">
  <div class="container mx-auto max-w-7xl px-4">
    <h2 class="font-sora text-[2rem] sm:text-[2.5rem] font-normal leading-[1.25] tracking-[-0.02em] text-black text-center mb-4 max-w-3xl mx-auto">
      Built to support every customer interaction with ease
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">
      {/* Card 1: Knowledge Base - from WA KnowledgeSourcesIllustration */}
      <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
        {/* Illustration with bottom fade */}
        <div class="relative overflow-hidden" style="height: 320px;">
          <div class="h-full w-full bg-gray-50">
            <div class="h-full w-full p-3 sm:p-4">
              <div class="bg-white rounded-lg border border-gray-200 shadow-sm h-full flex flex-col">
                {/* Header bar */}
                <div class="px-5 py-3.5 border-b border-gray-100 flex items-center gap-3">
                  <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                  <p class="text-[15px] font-semibold text-gray-900">Knowledge Base</p>
                </div>

                {/* Content */}
                <div class="flex-1 px-5 py-4 space-y-4 overflow-hidden">
                  {/* Sync tabs */}
                  <div class="flex gap-2.5">
                    <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-900 text-white text-[13px] font-medium">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z" />
                      </svg>
                      Apps
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 text-gray-400 text-[13px] font-medium">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.6 9h16.8M3.6 15h16.8" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.2 2.4 3.5 5.5 3.5 9s-1.3 6.6-3.5 9c-2.2-2.4-3.5-5.5-3.5-9s1.3-6.6 3.5-9z" />
                      </svg>
                      Website
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 text-gray-400 text-[13px] font-medium">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                      </svg>
                      Files
                    </div>
                  </div>

                  {/* Data source dropdown */}
                  <div>
                    <p class="text-[12px] text-gray-400 mb-1.5 font-medium">Select data source</p>
                    <div class="flex items-center justify-between px-4 py-2.5 rounded-lg border border-gray-200 bg-white">
                      <div class="flex items-center gap-2.5">
                        <img src="/images/logos/notion.png" alt="Notion" class="w-5 h-5 object-contain" />
                        <span class="text-[13px] text-gray-800 font-medium">Notion</span>
                      </div>
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </div>
                  </div>

                  {/* File tree */}
                  <div class="rounded-lg border border-gray-100 bg-gray-50 p-4 space-y-3">
                    {/* FAQs row */}
                    <div class="flex items-center gap-2.5">
                      <div class="w-[18px] h-[18px] rounded-[3px] border border-[#323dfe] bg-[#323dfe] flex items-center justify-center flex-shrink-0">
                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </div>
                      <span class="text-[13px] font-semibold text-gray-800">FAQs</span>
                      <span class="text-[12px] text-gray-400">9 pages</span>
                      <span class="ml-auto w-2 h-2 rounded-full bg-green-500" />
                    </div>

                    {/* Policies row */}
                    <div class="flex items-center gap-2.5">
                      <div class="w-[18px] h-[18px] rounded-[3px] border border-[#323dfe] bg-[#323dfe] flex items-center justify-center flex-shrink-0">
                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </div>
                      <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                      <span class="text-[13px] font-semibold text-gray-800">Policies</span>
                      <span class="text-[12px] text-gray-400">3 pages</span>
                      <span class="ml-auto w-2 h-2 rounded-full bg-green-500" />
                    </div>

                    {/* Sub-items */}
                    <div class="pl-6 space-y-2.5 border-l-2 border-gray-200 ml-2">
                      <div class="flex items-center gap-2.5">
                        <div class="w-[18px] h-[18px] rounded-[3px] border border-gray-300 bg-white flex-shrink-0" />
                        <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                        <div class="h-2 w-24 rounded-full bg-gray-200" />
                      </div>
                      <div class="flex items-center gap-2.5">
                        <div class="w-[18px] h-[18px] rounded-[3px] border border-gray-300 bg-white flex-shrink-0" />
                        <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                        <div class="h-2 w-16 rounded-full bg-gray-200" />
                      </div>
                    </div>

                    {/* Blog Posts row */}
                    <div class="flex items-center gap-2.5">
                      <div class="w-[18px] h-[18px] rounded-[3px] border border-gray-300 bg-white flex-shrink-0" />
                      <span class="text-[13px] font-medium text-gray-400">Blog Posts</span>
                      <span class="text-[12px] text-gray-300">124 posts</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          {/* Bottom fade */}
          <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none" />
        </div>

        {/* Text */}
        <div class="p-6">
          <h3 class="font-inter text-[1.25rem] font-semibold text-black mb-2">
            Conversations that sound like you and stay accurate
          </h3>
          <p class="text-[1rem] text-gray-600 leading-relaxed">
            AI agents adapt to your brand voice and pull answers from your latest knowledge base and connected data sources.
          </p>
        </div>
      </div>

      {/* Card 2: Human Handoff - from WA HumanInLoopIllustration */}
      <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
        {/* Illustration with bottom fade */}
        <div class="relative overflow-hidden" style="height: 320px;">
          <div class="h-full w-full bg-gray-50">
            <div class="h-full w-full p-3 sm:p-4">
              <div class="bg-white rounded-lg border border-gray-200 shadow-sm h-full flex flex-col">
                {/* Header */}
                <div class="px-4 py-3 border-b border-gray-100 flex items-center gap-3">
                  <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11l2 2 4-4" />
                  </svg>
                  <p class="text-sm font-semibold text-gray-900 flex-1">Agent Handoff</p>
                  <span class="text-[10px] px-2 py-1 rounded-md bg-blue-50 text-blue-700 font-medium border border-blue-200">
                    Active
                  </span>
                </div>

                {/* Content: Two panels side by side */}
                <div class="flex-1 flex overflow-hidden">
                  {/* Left: Flow diagram */}
                  <div class="flex-1 p-5 flex flex-col items-center justify-center border-r border-gray-100 bg-gray-50/50">
                    <div class="w-px h-8 border-l border-dashed border-gray-300" />

                    {/* Transfer node */}
                    <div class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl border border-gray-200 bg-white shadow-sm">
                      <span class="text-[13px] font-medium text-gray-800 whitespace-nowrap">Transfer to human agent</span>
                      <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487z" />
                      </svg>
                    </div>

                    {/* Dashed connector with dot */}
                    <div class="flex flex-col items-center">
                      <div class="w-px h-5 border-l border-dashed border-gray-300" />
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300" />
                      <div class="w-px h-5 border-l border-dashed border-gray-300" />
                    </div>

                    {/* Assign node */}
                    <div class="w-full max-w-[200px] rounded-xl border border-gray-200 bg-white shadow-sm p-3">
                      <div class="flex items-center gap-2.5 mb-2.5">
                        <div class="w-6 h-6 rounded-md bg-gray-100 flex items-center justify-center flex-shrink-0">
                          <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                          </svg>
                        </div>
                        <span class="text-[13px] font-medium text-gray-800 flex-1">Assign to IT team</span>
                        <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                          <circle cx="12" cy="6" r="1.5" />
                          <circle cx="12" cy="12" r="1.5" />
                          <circle cx="12" cy="18" r="1.5" />
                        </svg>
                      </div>
                      {/* Skeleton lines */}
                      <div class="space-y-2 pl-8">
                        <div class="h-2 w-full rounded-full bg-gray-100" />
                        <div class="h-2 w-4/5 rounded-full bg-gray-100" />
                        <div class="h-2 w-3/5 rounded-full bg-gray-100" />
                      </div>
                    </div>

                    {/* Plus button */}
                    <div class="mt-4">
                      <div class="w-7 h-7 rounded-full border border-dashed border-gray-300 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                      </div>
                    </div>
                  </div>

                  {/* Right: Settings panel */}
                  <div class="flex-1 p-5 flex flex-col">
                    <p class="text-[15px] font-semibold text-gray-900 mb-4">Transfer to human</p>

                    <p class="text-[13px] text-gray-500 font-medium mb-2">Assign to</p>

                    {/* Select dropdown */}
                    <div class="px-3.5 py-2.5 rounded-lg border border-gray-200 mb-4">
                      <span class="text-[13px] text-gray-400">Select agent or team</span>
                    </div>

                    {/* Tabs */}
                    <div class="flex gap-5 mb-4 border-b border-gray-100">
                      <span class="text-[13px] text-gray-400 pb-2.5">Human Agents</span>
                      <span class="text-[13px] font-semibold text-gray-900 pb-2.5 border-b-2 border-gray-900">Teams</span>
                    </div>

                    {/* Search */}
                    <div class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-lg border border-gray-200 mb-4">
                      <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                      </svg>
                      <span class="text-[13px] text-gray-400">Search Agents</span>
                    </div>

                    {/* Team list */}
                    <div class="space-y-3.5">
                      <div class="flex items-center gap-3">
                        <div class="w-[20px] h-[20px] rounded-[3px] border border-[#323dfe] bg-[#323dfe] flex items-center justify-center flex-shrink-0">
                          <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        </div>
                        <span class="text-[13px] font-medium text-gray-800">IT Support</span>
                        <span class="text-[12px] text-gray-400">(25 members)</span>
                      </div>

                      <div class="flex items-center gap-3">
                        <div class="w-[20px] h-[20px] rounded-[3px] border border-gray-200 bg-white flex-shrink-0" />
                        <div class="h-2.5 w-28 rounded-full bg-gray-100" />
                      </div>
                      <div class="flex items-center gap-3">
                        <div class="w-[20px] h-[20px] rounded-[3px] border border-gray-200 bg-white flex-shrink-0" />
                        <div class="h-2.5 w-24 rounded-full bg-gray-200" />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          {/* Bottom fade */}
          <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none" />
        </div>

        {/* Text */}
        <div class="p-6">
          <h3 class="font-inter text-[1.25rem] font-semibold text-black mb-2">
            Human in the loop
          </h3>
          <p class="text-[1rem] text-gray-600 leading-relaxed">
            Easily route conversations to the right support team when human help is needed. Assign by agent, team, or custom rules, without breaking the flow.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
