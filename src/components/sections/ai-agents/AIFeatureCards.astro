---
// AIFeatureCards.astro - 2-column feature cards with CSS illustrations
---

<section class="py-12 lg:py-16 bg-white">
  <div class="container mx-auto max-w-7xl px-4">
    <h2 class="font-sora text-[2rem] sm:text-[2.5rem] font-normal leading-[1.25] tracking-[-0.02em] text-black text-center mb-4">
      Built to support every customer interaction with ease
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">
      {/* Card 1: Knowledge Base */}
      <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
        {/* CSS Illustration */}
        <div class="bg-gray-50 p-6 border-b border-gray-200">
          <div class="rounded-lg bg-white border border-gray-200 p-4 shadow-sm max-w-sm mx-auto">
            {/* Mac controls */}
            <div class="flex items-center gap-2 mb-3">
              <div class="flex gap-1.5">
                <div class="w-2 h-2 rounded-full bg-red-300" />
                <div class="w-2 h-2 rounded-full bg-yellow-300" />
                <div class="w-2 h-2 rounded-full bg-green-300" />
              </div>
              <span class="text-[10px] text-gray-400 ml-2">Knowledge Base</span>
            </div>

            {/* Document list */}
            <div class="space-y-2">
              <div class="flex items-center gap-2 p-2 rounded-lg bg-[#323dfe]/5 border border-[#323dfe]/10">
                <svg class="w-4 h-4 text-[#323dfe] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <div class="flex-1 min-w-0">
                  <div class="text-[11px] font-medium text-black truncate">Return & Refund Policy</div>
                  <div class="text-[9px] text-gray-400">Updated 2 days ago</div>
                </div>
                <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50">
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <div class="flex-1 min-w-0">
                  <div class="text-[11px] font-medium text-gray-700 truncate">Product Catalog v3.2</div>
                  <div class="text-[9px] text-gray-400">Updated 5 days ago</div>
                </div>
                <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50">
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
                <div class="flex-1 min-w-0">
                  <div class="text-[11px] font-medium text-gray-700 truncate">FAQ & Troubleshooting</div>
                  <div class="text-[9px] text-gray-400">Updated 1 week ago</div>
                </div>
                <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
            </div>

            {/* Sync status */}
            <div class="mt-3 flex items-center gap-2 text-[10px] text-gray-500">
              <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" /></svg>
              <span>All sources synced</span>
              <span class="ml-auto text-[9px] text-gray-400">3 sources connected</span>
            </div>
          </div>
        </div>

        {/* Text */}
        <div class="p-6">
          <h3 class="font-sora text-[1.25rem] font-semibold text-black mb-2">
            Conversations that sound like you and stay accurate
          </h3>
          <p class="text-[1rem] text-gray-600 leading-relaxed">
            AI agents adapt to your brand voice and pull answers from your latest knowledge base and connected data sources.
          </p>
        </div>
      </div>

      {/* Card 2: Human Handoff */}
      <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
        {/* CSS Illustration */}
        <div class="bg-gray-50 p-6 border-b border-gray-200">
          <div class="rounded-lg bg-white border border-gray-200 p-4 shadow-sm max-w-sm mx-auto">
            {/* Conversation with handoff */}
            <div class="space-y-2.5">
              {/* Agent message */}
              <div class="flex gap-2">
                <div class="w-6 h-6 rounded-full bg-gradient-to-br from-[#cd3ef9] to-[#323dfe] flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0" />
                  </svg>
                </div>
                <div class="rounded-lg rounded-bl-sm px-2.5 py-1.5 bg-gray-100 text-[11px] text-gray-700 max-w-[80%]">
                  I understand your concern about the billing discrepancy. Let me connect you with our billing team for a detailed review.
                </div>
              </div>

              {/* Handoff indicator */}
              <div class="flex items-center gap-2 py-2">
                <div class="h-px flex-1 bg-gray-200" />
                <div class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 border border-amber-200">
                  <svg class="w-3 h-3 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                  </svg>
                  <span class="text-[10px] font-medium text-amber-700">Transferred to Billing Team</span>
                </div>
                <div class="h-px flex-1 bg-gray-200" />
              </div>

              {/* Human agent message */}
              <div class="flex gap-2">
                <div class="w-6 h-6 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0" />
                  </svg>
                </div>
                <div class="rounded-lg rounded-bl-sm px-2.5 py-1.5 bg-gray-100 text-[11px] text-gray-700 max-w-[80%]">
                  <div class="text-[10px] font-semibold text-emerald-600 mb-0.5">Sarah — Billing Specialist</div>
                  Hi! I've reviewed your account and found the issue. I'm processing a correction now.
                </div>
              </div>

              {/* Routing rules */}
              <div class="mt-2 pt-2 border-t border-gray-100">
                <div class="text-[9px] text-gray-400 font-medium mb-1.5">ROUTING RULES</div>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 rounded-full bg-blue-50 text-[9px] text-blue-600 font-medium">By team</span>
                  <span class="px-2 py-0.5 rounded-full bg-purple-50 text-[9px] text-purple-600 font-medium">By agent skill</span>
                  <span class="px-2 py-0.5 rounded-full bg-green-50 text-[9px] text-green-600 font-medium">Custom rules</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Text */}
        <div class="p-6">
          <h3 class="font-sora text-[1.25rem] font-semibold text-black mb-2">
            Human in the loop
          </h3>
          <p class="text-[1rem] text-gray-600 leading-relaxed">
            Easily route conversations to the right support team when human help is needed. Assign by agent, team, or custom rules, without breaking the flow.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
