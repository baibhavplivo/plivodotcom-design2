---
// ChatIntegrations.astro - Dual-row scrolling integration logos for Chat channel

const row1 = [
  { name: "Salesforce", icon: "salesforce" },
  { name: "HubSpot", icon: "hubspot" },
  { name: "Zoho CRM", icon: "zoho" },
  { name: "Shopify", icon: "shopify" },
  { name: "Zapier", icon: "zapier" },
  { name: "Woo", icon: "woo" },
  { name: "Stripe", icon: "stripe" },
  { name: "Intercom", icon: "intercom" },
];

const row2 = [
  { name: "Zendesk", icon: "zendesk" },
  { name: "Freshdesk", icon: "freshdesk" },
  { name: "Zoho Desk", icon: "zoho-desk" },
  { name: "Slack", icon: "slack" },
  { name: "Google Calendar", icon: "google-calendar" },
  { name: "Calendly", icon: "calendly" },
  { name: "ServiceNow", icon: "servicenow" },
  { name: "GitHub", icon: "github" },
];
---

<section class="py-12 lg:py-16 bg-background border-t border-border">
  <div class="container mx-auto max-w-7xl px-4 mb-10">
    <div class="flex items-center gap-3 font-mono-ui text-[11px] uppercase tracking-[0.12em] text-muted-foreground mb-8">
          <span class="flex items-center gap-2">
            <span class="tabular-nums text-foreground/70">~</span>
            <span class="h-px w-6 bg-border"></span>
          </span>
          <span>integrations</span>
          <span class="flex-1 border-t border-dashed border-border"></span>
        </div>
        <h2 class="font-sora text-[2rem] sm:text-[2.5rem] font-normal leading-[1.04] tracking-[-0.035em] text-foreground">
      Integrates with your favorite tools
    </h2>
    <p class="text-base sm:text-lg text-muted-foreground mt-4 max-w-2xl leading-relaxed">
      Connect your CRM, helpdesk, e-commerce platform, and more so every AI agent can work with your existing stack.
    </p>
  </div>

  <div class="relative overflow-hidden space-y-3">
    {/* Row 1 - Left to right */}
    <div class="chat-int-marquee-wrapper">
      <div class="chat-int-marquee-row1 flex gap-3 sm:gap-4">
        {[...row1, ...row1, ...row1, ...row1].map((item) => (
          <div class="flex-shrink-0 flex items-center gap-3 px-5 py-3 rounded-lg bg-background border border-border hover:bg-surface transition-colors">
            <img src={`/images/integrations/${item.icon}.svg`} alt={item.name} class="w-6 h-6 flex-shrink-0 object-contain" />
            <span class="text-sm font-medium text-foreground/80 whitespace-nowrap">{item.name}</span>
          </div>
        ))}
      </div>
    </div>

    {/* Row 2 - Right to left */}
    <div class="chat-int-marquee-wrapper">
      <div class="chat-int-marquee-row2 flex gap-3 sm:gap-4">
        {[...row2, ...row2, ...row2, ...row2].map((item) => (
          <div class="flex-shrink-0 flex items-center gap-3 px-5 py-3 rounded-lg bg-background border border-border hover:bg-surface transition-colors">
            <img src={`/images/integrations/${item.icon}.svg`} alt={item.name} class="w-6 h-6 flex-shrink-0 object-contain" />
            <span class="text-sm font-medium text-foreground/80 whitespace-nowrap">{item.name}</span>
          </div>
        ))}
      </div>
    </div>

    {/* Fade edges */}
    <div class="absolute inset-y-0 left-0 w-24 sm:w-40 bg-gradient-to-r from-background to-transparent z-10 pointer-events-none" />
    <div class="absolute inset-y-0 right-0 w-24 sm:w-40 bg-gradient-to-l from-background to-transparent z-10 pointer-events-none" />
  </div>
</section>

<style>
  .chat-int-marquee-row1 {
    animation: chat-int-marquee-ltr 50s linear infinite;
  }

  .chat-int-marquee-row2 {
    animation: chat-int-marquee-rtl 50s linear infinite;
  }

  .chat-int-marquee-wrapper:hover .chat-int-marquee-row1,
  .chat-int-marquee-wrapper:hover .chat-int-marquee-row2 {
    animation-play-state: paused;
  }

  @keyframes chat-int-marquee-ltr {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes chat-int-marquee-rtl {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
</style>
