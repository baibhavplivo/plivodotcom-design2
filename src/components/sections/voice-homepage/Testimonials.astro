---
// Testimonials.astro - Customer testimonials section

const testimonials = [
  {
    quote: "This library has completely transformed how we build our UI components. The attention to detail and smooth animations make our application stand out. Highly recommended!",
    name: "Sarah Johnson",
    role: "Product Manager @ Amazun",
    avatar: "/images/avatars/testimonial-1.jpg",
    rating: 5,
  },
  {
    quote: "The components are well documented and easy to customize. The code quality is top-notch and the support is excellent. I'm very happy with my purchase.",
    name: "John Doe",
    role: "Software Engineer @ Goggle",
    avatar: "/images/avatars/testimonial-2.jpg",
    rating: 4,
  },
  {
    quote: "The accessibility features and design system consistency are impressive. It's saved us countless hours in development time.",
    name: "Emily Chen",
    role: "UX Designer @ Microsift",
    avatar: "/images/avatars/testimonial-3.jpg",
    rating: 5,
  },
];
---

<section class="testimonial-section relative bg-background py-12 sm:py-16 md:py-20">
  <div class="container mx-auto max-w-7xl px-4 relative z-10">
    <h2 class="font-sora text-[1.75rem] sm:text-[2rem] md:text-[2.5rem] font-normal leading-[1.25] tracking-[-0.02em] text-foreground text-center mb-6 max-w-3xl mx-auto">
      Trusted by 10,000+ businesses worldwide
    </h2>

    <div class="grid gap-4 sm:gap-6 md:grid-cols-3 py-2">
      {testimonials.map((testimonial) => (
        <div class="testimonial-card bg-background border border-border rounded-lg p-4 sm:p-6 transition-colors">
          {/* Quote Icon */}
          <div class="text-5xl text-gray-200 font-serif leading-none mb-4">"</div>

          {/* Stars */}
          <div class="flex gap-1 mb-4">
            {[1, 2, 3, 4, 5].map((star) => (
              <svg
                class={`w-4 h-4 ${star <= testimonial.rating ? "text-yellow-400 fill-yellow-400" : "text-gray-300"}`}
                viewBox="0 0 24 24"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))}
          </div>

          {/* Quote */}
          <p class="text-foreground/80 text-sm leading-relaxed mb-6 flex-1">
            {testimonial.quote}
          </p>

          {/* Author */}
          <div class="flex items-center gap-3 mt-auto">
            <img
              src={testimonial.avatar}
              alt={testimonial.name}
              class="w-10 h-10 rounded-full object-cover"
            />
            <div>
              <div class="font-medium text-foreground text-sm">{testimonial.name}</div>
              <div class="text-xs text-muted-foreground">{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
