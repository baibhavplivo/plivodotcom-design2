---
// Compliance.astro - Section 06 / compliance
// Split: headline + copy on left, badges band + spec grid on right.

const badges = [
  { src: "/images/compliance/HIPAA black.svg", alt: "HIPAA", label: "HIPAA" },
  { src: "/images/compliance/GDPR black.svg", alt: "GDPR", label: "GDPR" },
  { src: "/images/compliance/AICPA black.svg", alt: "AICPA SOC 2", label: "SOC 2" },
  { src: "/images/compliance/PCI black.svg", alt: "PCI DSS", label: "PCI DSS" },
  { src: "/images/compliance/Star Black.svg", alt: "STAR", label: "STAR" },
];

const features = [
  {
    title: "Encryption everywhere",
    description: "TLS in transit. AES-256 at rest. No exceptions.",
    meta: "tls · aes-256",
  },
  {
    title: "Data residency",
    description: "Choose US, EU, or APAC. Your data stays where you need it.",
    meta: "us · eu · apac",
  },
  {
    title: "Audit-ready",
    description: "Full access logs, RBAC, and compliance reports on demand.",
    meta: "logs · rbac · reports",
  },
];
---

<section id="section-compliance" class="relative w-full border-t border-border">
  <div class="container mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-20 md:py-24">
    <!-- Kicker -->
    <div class="flex items-center gap-3 font-mono-ui text-[11px] uppercase tracking-[0.12em] text-muted-foreground">
      <span class="flex items-center gap-2">
        <span class="tabular-nums text-foreground/70">06</span>
        <span class="h-px w-6 bg-border"></span>
      </span>
      <span>security & compliance</span>
      <span class="flex-1 border-t border-dashed border-border"></span>
      <span>hipaa · gdpr · soc 2 · pci dss</span>
    </div>

    <!-- Split layout -->
    <div class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
      <!-- Left: headline + copy -->
      <div class="lg:col-span-5 lg:pt-2">
        <h2 class="font-sora text-[2rem] font-normal leading-[1.04] tracking-[-0.035em] text-foreground sm:text-[2.5rem]">
          Enterprise-grade security<br />& compliance
        </h2>
      </div>

      <!-- Right: badges + features -->
      <div class="lg:col-span-7">
        <div class="overflow-hidden rounded-lg border border-border bg-surface">
          <!-- Badges strip -->
          <div class="relative grid grid-cols-5 divide-x divide-border border-b border-border">
            {badges.map((badge) => (
              <div class="relative flex flex-col items-center gap-2 px-2 py-6 transition-colors hover:bg-background/50 [&_img]:brightness-0 dark:[&_img]:invert [&_img]:opacity-75">
                <div class="flex h-10 w-10 items-center justify-center sm:h-12 sm:w-12">
                  <img src={badge.src} alt={badge.alt} class="max-h-full max-w-full" />
                </div>
                <span class="font-mono-ui text-[10px] uppercase tracking-[0.08em] text-muted-foreground">
                  {badge.label}
                </span>
              </div>
            ))}
          </div>

          <!-- Features list -->
          <ul class="divide-y divide-border">
            {features.map((feature) => (
              <li class="group flex items-start gap-4 px-5 py-4 sm:px-6 sm:py-5 transition-colors hover:bg-background/50">
                <svg
                  class="mt-1 h-4 w-4 shrink-0 text-primary"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <div class="flex flex-1 flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
                  <div>
                    <h4 class="font-sora text-[14.5px] font-semibold tracking-[-0.01em] text-foreground">
                      {feature.title}
                    </h4>
                    <p class="mt-0.5 text-[13px] text-muted-foreground">{feature.description}</p>
                  </div>
                  <span class="font-mono-ui shrink-0 text-[10.5px] uppercase tracking-[0.08em] text-muted-foreground">
                    {feature.meta}
                  </span>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
