<style>
  .marquee-content {
    animation: marquee 30s linear infinite;
  }
  .marquee-container:hover .marquee-content {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<script>
  function initClientLogos() {
    const indiaEl = document.getElementById("logos-india");
    const intlEl = document.getElementById("logos-international");
    if (!indiaEl || !intlEl) return;

    const show = (country: string) => {
      if (country === "IN") {
        indiaEl.style.display = "";
        intlEl.style.display = "none";
      }
    };

    // 1. Server-injected CF-IPCountry (instant, no network call)
    const cfCountry = (window as any).__CF_COUNTRY;
    if (cfCountry) {
      show(cfCountry);
      return;
    }

    // 2. Primary geo system (useGeoCountry hook stores here via ipapi.co)
    try {
      const geoCountry = sessionStorage.getItem("plivo_geo_country");
      if (geoCountry) { show(geoCountry); return; }
    } catch {}

    // 3. Secondary geo system (ipinfo.io / intl-tel-input cache)
    try {
      const cached = sessionStorage.getItem("plivo_ip_info");
      if (cached) { show(JSON.parse(cached).country); return; }
    } catch {}

    // 4. Poll for either key (geo detection is async)
    let attempts = 0;
    const poll = setInterval(() => {
      attempts++;
      try {
        const gc = sessionStorage.getItem("plivo_geo_country");
        if (gc) { show(gc); clearInterval(poll); return; }
        const ip = sessionStorage.getItem("plivo_ip_info");
        if (ip) { show(JSON.parse(ip).country); clearInterval(poll); return; }
      } catch {}
      if (attempts > 40) clearInterval(poll);
    }, 100);
  }
  initClientLogos();
  document.addEventListener("astro:after-swap", initClientLogos);
</script>
