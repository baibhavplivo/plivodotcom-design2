---
// ClientLogos.astro - Logo marquee between 2 lines
// Shows different logo sets based on visitor country (IN vs RoW)
// "Trusted by leading enterprises worldwide" text on the left
---

<section class="relative bg-white">

  <!-- Static logos - India set (shown for IN visitors) -->
  <div id="logos-india" style="display:none;">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:py-16 flex items-center">
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center justify-center gap-x-6 sm:gap-x-8 gap-y-2">
          <img src="/images/client-logos/meta.svg" alt="Meta" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/atomberg.svg" alt="Atomberg" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/uber.svg" alt="Uber" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/trip.com.svg" alt="Trip.com" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/zomato.svg" alt="Zomato" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/masai.svg" alt="Masai" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/discord.svg" alt="Discord" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-6 sm:gap-x-8 gap-y-2 mt-1">
          <img src="/images/client-logos/great-learning.svg" alt="Great Learning" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/amul.svg" alt="Amul" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/zolve.svg" alt="Zolve" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/godaddy.svg" alt="GoDaddy" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/tata-1mg.svg" alt="Tata 1mg" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/yahoo.svg" alt="Yahoo" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/healthify.svg" alt="Healthify" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
        </div>
      </div>
    </div>
  </div>

  <!-- Static logos - International set (default, shown for US/RoW visitors) -->
  <div id="logos-international">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:py-16 flex items-center">
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center justify-center gap-x-6 sm:gap-x-8 gap-y-2">
          <img src="/images/client-logos/meta.svg" alt="Meta" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/decker-brands.svg" alt="Decker Brands" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/adobe.svg" alt="Adobe" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/trip.com.svg" alt="Trip.com" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/uber.svg" alt="Uber" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/laz-parking.svg" alt="Laz Parking" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-6 sm:gap-x-8 gap-y-2 mt-1">
          <img src="/images/client-logos/discord.svg" alt="Discord" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/atlassian.svg" alt="Atlassian" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/godaddy.svg" alt="GoDaddy" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/docusign.svg" alt="DocuSign" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
          <img src="/images/client-logos/yahoo.svg" alt="Yahoo" class="h-14 sm:h-16 w-auto opacity-80 hover:opacity-100 transition-opacity" />
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  function initClientLogos() {
    const indiaEl = document.getElementById("logos-india");
    const intlEl = document.getElementById("logos-international");
    if (!indiaEl || !intlEl) return;

    const show = (country: string) => {
      if (country === "IN") {
        indiaEl.style.display = "";
        intlEl.style.display = "none";
      }
    };

    // 1. Server-injected CF-IPCountry (instant, no network call)
    const cfCountry = (window as any).__CF_COUNTRY;
    if (cfCountry) {
      show(cfCountry);
      return;
    }

    // 2. Primary geo system (useGeoCountry hook stores here via ipapi.co)
    try {
      const geoCountry = sessionStorage.getItem("plivo_geo_country");
      if (geoCountry) { show(geoCountry); return; }
    } catch {}

    // 3. Secondary geo system (ipinfo.io / intl-tel-input cache)
    try {
      const cached = sessionStorage.getItem("plivo_ip_info");
      if (cached) { show(JSON.parse(cached).country); return; }
    } catch {}

    // 4. Poll for either key (geo detection is async)
    let attempts = 0;
    const poll = setInterval(() => {
      attempts++;
      try {
        const gc = sessionStorage.getItem("plivo_geo_country");
        if (gc) { show(gc); clearInterval(poll); return; }
        const ip = sessionStorage.getItem("plivo_ip_info");
        if (ip) { show(JSON.parse(ip).country); clearInterval(poll); return; }
      } catch {}
      if (attempts > 40) clearInterval(poll);
    }, 100);
  }
  initClientLogos();
  document.addEventListener("astro:after-swap", initClientLogos);
</script>
