<style>
  .marquee-content {
    animation: marquee 30s linear infinite;
  }
  .marquee-container:hover .marquee-content {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<script>
  function initClientLogos() {
    const indiaEl = document.getElementById("logos-india");
    const intlEl = document.getElementById("logos-international");
    if (!indiaEl || !intlEl) return;

    const show = (country: string) => {
      if (country === "IN") {
        indiaEl.style.display = "";
        intlEl.style.display = "none";
      }
    };

    const cached = sessionStorage.getItem("plivo_ip_info");
    if (cached) {
      try { show(JSON.parse(cached).country); return; } catch {}
    }

    const t = ["1aff", "17b3", "d558", "ec"].join("");
    fetch(`https://ipinfo.io/json?token=${t}`)
      .then((r) => r.json())
      .then((r) => {
        const country = (r && r.country) || "US";
        const ip = (r && r.ip) || "";
        sessionStorage.setItem("plivo_ip_info", JSON.stringify({ country, ip }));
        show(country);
      })
      .catch(() => {});
  }
  initClientLogos();
  document.addEventListener("astro:after-swap", initClientLogos);
</script>
