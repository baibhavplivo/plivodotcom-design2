---
// VoiceHero.astro - Section 01 / voice ai
// Editorial hero, left-aligned, with live voice-agent animation on the right.
import VoiceAgentDemo from "@/components/sections/voice-homepage/VoiceAgentDemo";
---

<section id="section-voice" class="relative w-full overflow-hidden">
  <!-- Subtle grid backdrop, masked to the hero area -->
  <div class="pointer-events-none absolute inset-0 dev-grid-bg opacity-[0.35] [mask-image:linear-gradient(to_bottom,black_40%,transparent_95%)]"></div>

  <div class="relative container mx-auto max-w-7xl px-4 sm:px-6 pt-10 pb-14 sm:pt-14 sm:pb-20 md:pt-20 md:pb-24">
    <!-- Kicker strip -->
    <div class="flex items-center gap-3 font-mono-ui text-[11px] uppercase tracking-[0.12em] text-muted-foreground">
      <span class="flex items-center gap-2">
        <span class="tabular-nums text-foreground/70">01</span>
        <span class="h-px w-6 bg-border"></span>
      </span>
      <span>voice ai</span>
      <span class="flex-1 border-t border-dashed border-border"></span>
      <!-- Channel pills inline with the kicker -->
      <div class="hidden items-center gap-1 sm:flex">
        <span class="text-muted-foreground/80">available on</span>
        <span class="mx-1 text-border">·</span>
        <a href="/voice/overview/" class="rounded px-1.5 py-0.5 text-foreground/80 hover:bg-surface hover:text-foreground transition-colors">voice</a>
        <a href="/sms/overview/" class="rounded px-1.5 py-0.5 text-foreground/80 hover:bg-surface hover:text-foreground transition-colors">sms</a>
        <a href="/whatsapp-message/overview/" class="rounded px-1.5 py-0.5 text-foreground/80 hover:bg-surface hover:text-foreground transition-colors">whatsapp</a>
        <a href="/chat/overview/" class="rounded px-1.5 py-0.5 text-foreground/80 hover:bg-surface hover:text-foreground transition-colors">chat</a>
      </div>
    </div>

    <!-- Headline + aside grid -->
    <div class="mt-10 grid grid-cols-1 gap-10 lg:mt-14 lg:grid-cols-12 lg:gap-12">
      <!-- Left: headline, copy, CTAs -->
      <div class="lg:col-span-7">
        <h1 class="font-sora text-[2.25rem] font-normal leading-[1.02] tracking-[-0.04em] text-foreground sm:text-[3rem] md:text-[3.75rem]">
          Build human-like
          <br />
          <span class="[text-decoration-line:underline] decoration-primary/25 [text-decoration-thickness:0.14em] [text-underline-offset:0.12em]">voice AI agents</span>
        </h1>
        <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-muted-foreground sm:text-base">
          From no-code builders for teams to flexible APIs for developers, deploy voice agents that actually sound human.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href="https://cx.plivo.com/pungis2"
            data-geo-cta="signup"
            class="group inline-flex items-center rounded-md bg-foreground px-4 py-2.5 text-[13.5px] font-medium text-background transition-colors hover:bg-primary hover:text-white"
          >
            Start for free
            <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a
            href="https://www.plivo.com/docs/"
            class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-4 py-2.5 text-[13.5px] font-medium text-foreground transition-colors hover:border-border-strong hover:bg-surface"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
            Read the docs
          </a>
          <span id="hero-credits-text" class="font-mono-ui ml-1 text-[11px] text-muted-foreground">
            $10 in free credits.
          </span>
        </div>

        <!-- Micro metrics row -->
        <dl class="mt-10 grid grid-cols-3 gap-4 border-t border-border pt-6 sm:max-w-lg">
          <div>
            <dt class="font-mono-ui text-[10px] uppercase tracking-[0.12em] text-muted-foreground">latency</dt>
            <dd class="mt-1 font-mono-ui text-xl font-semibold tabular-nums text-foreground">&lt;500<span class="text-muted-foreground text-sm">ms</span></dd>
          </div>
          <div>
            <dt class="font-mono-ui text-[10px] uppercase tracking-[0.12em] text-muted-foreground">uptime</dt>
            <dd class="mt-1 font-mono-ui text-xl font-semibold tabular-nums text-foreground">99.99<span class="text-muted-foreground text-sm">%</span></dd>
          </div>
          <div>
            <dt class="font-mono-ui text-[10px] uppercase tracking-[0.12em] text-muted-foreground">countries</dt>
            <dd class="mt-1 font-mono-ui text-xl font-semibold tabular-nums text-foreground">150<span class="text-muted-foreground text-sm">+</span></dd>
          </div>
        </dl>
      </div>

      <!-- Right: live voice agent animation -->
      <div class="lg:col-span-5">
        <VoiceAgentDemo client:load />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function swapCredits(country) {
      if (country === "IN") {
        var el = document.getElementById("hero-credits-text");
        if (el) el.textContent = "₹1,000 in free credits.";
      }
    }
    var cf = window.__CF_COUNTRY;
    if (cf && cf !== "XX") { swapCredits(cf); return; }
    try { var gc = sessionStorage.getItem("plivo_geo_country"); if (gc) { swapCredits(gc); return; } } catch (e) {}
    try { var ip = sessionStorage.getItem("plivo_ip_info"); if (ip) { swapCredits(JSON.parse(ip).country); return; } } catch (e) {}
    var attempts = 0;
    var poll = setInterval(function () {
      attempts++;
      try {
        var gc2 = sessionStorage.getItem("plivo_geo_country");
        if (gc2) { swapCredits(gc2); clearInterval(poll); return; }
      } catch (e) {}
      if (attempts > 30) clearInterval(poll);
    }, 100);
  })();
</script>
