---
// VoiceHero.astro - Hero section for Voice AI homepage
---

<section class="hero bg-white pt-10 sm:pt-16 md:pt-20">
  <div class="container mx-auto max-w-7xl px-4 text-center">
    <!-- Available on pill with clickable channels -->
    <div class="mb-6 flex justify-center">
      <div class="inline-flex items-center gap-0.5 sm:gap-1 rounded-full border border-gray-200 px-2 sm:px-3 py-1 sm:py-1.5">
        <span class="text-[10px] sm:text-xs font-medium text-gray-500 mr-0.5 sm:mr-1">Available on</span>
        <a href="/voice/overview" class="inline-flex items-center gap-0.5 sm:gap-1 rounded-full px-2.5 sm:px-3 py-1 sm:py-1.5 text-[10px] sm:text-xs font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900">
          <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          Voice
        </a>
        <a href="/sms/overview" class="inline-flex items-center gap-0.5 sm:gap-1 rounded-full px-2.5 sm:px-3 py-1 sm:py-1.5 text-[10px] sm:text-xs font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900">
          <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          SMS
        </a>
        <a href="/whatsapp-message/overview" class="inline-flex items-center gap-0.5 sm:gap-1 rounded-full px-2.5 sm:px-3 py-1 sm:py-1.5 text-[10px] sm:text-xs font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900">
          <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          WhatsApp
        </a>
        <a href="/chat/overview" class="inline-flex items-center gap-0.5 sm:gap-1 rounded-full px-2.5 sm:px-3 py-1 sm:py-1.5 text-[10px] sm:text-xs font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900">
          <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          Chat
        </a>
      </div>
    </div>
    <h1 class="font-sora text-[2rem] sm:text-[2.5rem] md:text-[3rem] font-normal leading-[1.1] tracking-[-0.02em] text-black">
      Build human-like voice AI agents
    </h1>
    <p class="text-base sm:text-lg md:text-xl text-gray-600 mt-3 max-w-[700px] mx-auto leading-relaxed">
      From no-code builders for teams to flexible APIs for developers, deploy voice agents that actually sound human.
    </p>
  </div>

  <!-- CTA area + flickering grid behind it -->
  <div class="flicker-area relative overflow-hidden" style="height:320px;">
    <canvas id="hero-flicker-canvas" class="absolute inset-0 z-0 pointer-events-none" style="top:160px;"></canvas>
    <!-- Gradual top fade -->
    <div class="absolute inset-x-0 top-0 z-[1] pointer-events-none" style="height:85%;background:linear-gradient(to bottom,white 55%,transparent);"></div>
    <!-- Left/right fades -->
    <div class="absolute inset-y-0 left-0 w-20 sm:w-32 bg-gradient-to-r from-white to-transparent z-[1] pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-20 sm:w-32 bg-gradient-to-l from-white to-transparent z-[1] pointer-events-none"></div>
    <!-- CTA content on top of dots -->
    <div class="relative z-[2] text-center pt-6">
      <div class="flex justify-center">
        <a
          href="https://cx.plivo.com/pungis2"
          data-geo-cta="signup"
          class="beam-btn relative inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-black text-white rounded-md cta-hover-gradient transition-colors overflow-hidden"
        >
          <span class="beam-border"></span>
          <span class="relative z-10">Start for free</span>
        </a>
      </div>
      <p class="text-sm text-gray-500 mt-4 leading-relaxed">
        $10 in free credits.<br />
        No credit card required.
      </p>
    </div>
  </div>
</section>

<style>
  .beam-btn {
    isolation: isolate;
  }
  .beam-border {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    pointer-events: none;
  }
  .beam-border::before {
    content: "";
    position: absolute;
    inset: -200%;
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 70%,
      #323dfe 76%,
      #8b5cf6 82%,
      #cd3ef9 88%,
      transparent 92%,
      transparent 100%
    );
    animation: beam-spin 3s linear infinite;
  }
  .beam-border::after {
    content: "";
    position: absolute;
    inset: 2.5px;
    border-radius: inherit;
    background: black;
  }
  .beam-btn:hover .beam-border::after {
    background-image: linear-gradient(to left, #000000, #4f46e5, #d946ef);
  }
  @keyframes beam-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  function initHeroFlicker() {
    const canvas = document.getElementById("hero-flicker-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;
    const container = canvas.parentElement as HTMLElement | null;
    if (!container) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const SQ = 5, GAP = 5, MAX_OP = 0.55, FLICKER = 0.15;
    const COLOR = "139, 92, 246";
    let cols = 0, rows = 0, squares = new Float32Array(0), raf: number;

    const setup = () => {
      const w = container.clientWidth, h = container.clientHeight;
      if (w <= 0 || h <= 0) return;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = w * dpr; canvas.height = h * dpr;
      canvas.style.width = `${w}px`; canvas.style.height = `${h}px`;
      cols = Math.floor(w / (SQ + GAP));
      rows = Math.floor(h / (SQ + GAP));
      squares = new Float32Array(cols * rows);
      for (let i = 0; i < squares.length; i++) squares[i] = Math.random() * MAX_OP;
    };
    setup();

    let last = 0;
    const draw = (t: number) => {
      if (!cols || !rows) { setup(); last = t; raf = requestAnimationFrame(draw); return; }
      const dt = (t - last) / 1000; last = t;
      const dpr = window.devicePixelRatio || 1;
      for (let i = 0; i < squares.length; i++) {
        if (Math.random() < FLICKER * dt) squares[i] = Math.random() * MAX_OP;
      }
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          ctx.fillStyle = `rgba(${COLOR}, ${squares[i * rows + j]})`;
          ctx.fillRect(i * (SQ + GAP) * dpr, j * (SQ + GAP) * dpr, SQ * dpr, SQ * dpr);
        }
      }
      raf = requestAnimationFrame(draw);
    };
    raf = requestAnimationFrame(draw);

    const ro = new ResizeObserver(() => setup());
    ro.observe(container);
  }
  initHeroFlicker();
  document.addEventListener("astro:after-swap", initHeroFlicker);
</script>
