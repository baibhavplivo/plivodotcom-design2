---
// SIPTrunkingHero.astro - editorial SIP trunking hero
import SIPTrunkingHeroIllustration from "./SIPTrunkingHeroIllustration";
---

<section class="relative w-full overflow-hidden">
  <div class="pointer-events-none absolute inset-0 dev-grid-bg opacity-[0.3] [mask-image:linear-gradient(to_bottom,black_40%,transparent_95%)]"></div>

  <div class="relative container mx-auto max-w-7xl px-4 sm:px-6 pt-10 pb-14 sm:pt-14 sm:pb-20 md:pt-20 md:pb-24">
    <div class="flex items-center gap-3 font-mono-ui text-[11px] uppercase tracking-[0.12em] text-muted-foreground">
      <span class="flex items-center gap-2">
        <span class="tabular-nums text-foreground/70">~</span>
        <span class="h-px w-6 bg-border"></span>
      </span>
      <span>sip trunking</span>
      <span class="flex-1 border-t border-dashed border-border"></span>
      <span>cloud · unlimited channels · pay-as-you-go</span>
    </div>

    <div class="mt-10 grid grid-cols-1 items-center gap-10 lg:mt-14 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-7">
        <h1 class="font-sora text-[2.25rem] font-normal leading-[1.02] tracking-[-0.04em] text-foreground sm:text-[3rem] md:text-[3.5rem]">
          <span class="[text-decoration-line:underline] decoration-primary/25 [text-decoration-thickness:0.14em] [text-underline-offset:0.12em]">Cloud-based SIP trunking</span>
        </h1>
        <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-muted-foreground sm:text-base">
          Global connectivity and unlimited concurrent calls with flexible pay-as-you-go pricing. Connect your VoIP infrastructure in minutes.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href="https://cx.plivo.com/pungis2"
            data-geo-cta="signup"
            class="group inline-flex items-center rounded-md bg-foreground px-4 py-2.5 text-[13.5px] font-medium text-background transition-colors hover:bg-primary hover:text-white"
          >
            Sign up for free
            <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a
            href="/contact/sales/"
            class="inline-flex items-center rounded-md border border-border bg-background px-4 py-2.5 text-[13.5px] font-medium text-foreground transition-colors hover:border-border-strong hover:bg-surface"
          >
            Get volume pricing
          </a>
        </div>

        <dl class="mt-10 grid grid-cols-3 gap-4 border-t border-border pt-6 sm:max-w-lg">
          <div>
            <dt class="font-mono-ui text-[10px] uppercase tracking-[0.12em] text-muted-foreground">countries</dt>
            <dd class="mt-1 font-mono-ui text-xl font-semibold tabular-nums text-foreground">190<span class="text-muted-foreground text-sm">+</span></dd>
          </div>
          <div>
            <dt class="font-mono-ui text-[10px] uppercase tracking-[0.12em] text-muted-foreground">channels</dt>
            <dd class="mt-1 font-mono-ui text-xl font-semibold tabular-nums text-foreground">∞</dd>
          </div>
          <div>
            <dt class="font-mono-ui text-[10px] uppercase tracking-[0.12em] text-muted-foreground">uptime</dt>
            <dd class="mt-1 font-mono-ui text-xl font-semibold tabular-nums text-foreground">99.99<span class="text-muted-foreground text-sm">%</span></dd>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-5">
        <SIPTrunkingHeroIllustration client:visible />
      </div>
    </div>
  </div>
</section>
