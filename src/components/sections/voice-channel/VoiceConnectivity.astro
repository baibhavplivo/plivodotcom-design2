---
// VoiceConnectivity.astro - Feature list section for voice connectivity
import AnimatedPhoneNumbers from "./AnimatedPhoneNumbers";

const features = [
  {
    title: "Seamless inbound calling in 50+ countries",
    description: "Global coverage with local numbers in 50+ countries for AI agent accessibility.",
  },
  {
    title: "Direct PSTN connectivity without complexity",
    description: "Connect directly to phone networks without managing carrier relationships.",
  },
  {
    title: "Branded calling",
    description: "Display your business name on caller ID to boost trust and answer rates.",
  },
  {
    title: "CNAM for legitimacy",
    description: "Caller Name (CNAM) registration ensures your calls appear legitimate.",
  },
  {
    title: "SHAKEN/STIR compliance",
    description: "Full attestation compliance to prevent spam flagging and call blocking.",
  },
];

// Check icon SVG path (Heroicons check)
const checkIconPath = "M4.5 12.75l6 6 9-13.5";
---

<section class="bg-white py-12 sm:py-16 md:py-20">
  <div class="container mx-auto max-w-7xl px-4">
    <!-- Section Header -->
    <h2 class="font-sora text-[1.75rem] sm:text-[2rem] md:text-[2.5rem] font-normal leading-[1.25] tracking-[-0.02em] text-black text-center mb-10 md:mb-14">
      Powerful voice connectivity for<br />AI-powered conversations
    </h2>

    <!-- Two Column Layout -->
    <div class="grid gap-8 lg:grid-cols-[1fr_1.2fr] lg:gap-12 items-start">
      <!-- Left - Features List with CTA -->
      <div class="flex flex-col">
        <div class="divide-y divide-gray-200">
          {features.map((feature) => (
            <div class="flex gap-3 py-5 first:pt-0 last:pb-0">
              <!-- Check Icon -->
              <div class="flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-[#323dfe]" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={checkIconPath} />
                </svg>
              </div>
              <!-- Text -->
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-black mb-1">{feature.title}</h3>
                <p class="text-sm text-gray-500">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA - 60px below text -->
        <div class="mt-[60px]">
          <a
            href="/contact/sales/"
            class="inline-flex items-center justify-center rounded-md bg-black px-6 py-3 text-sm font-medium text-white transition-colors cta-hover-gradient"
          >
            Get started
          </a>
        </div>
      </div>

      <!-- Right - Animated Phone Numbers -->
      <div class="flex justify-center lg:justify-end">
        <div class="w-full max-w-[620px] h-[620px] rounded-lg overflow-hidden">
          <AnimatedPhoneNumbers client:visible />
        </div>
      </div>
    </div>
  </div>
</section>
