---
// VerifyHero.astro - Side-by-side hero with OTP verification illustration
import VerifyHeroIllustration from "./VerifyHeroIllustration";
---

<section class="hero bg-white pt-[56px] sm:pt-[64px] md:pt-[72px] pb-8">
  <div class="container mx-auto max-w-7xl px-4">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 items-center">
      <!-- Left Content -->
      <div class="order-1 lg:order-1 max-w-[820px] text-center lg:text-left">
        <h1 class="font-sora text-[2rem] sm:text-[2.5rem] md:text-[3rem] font-normal leading-[1.1] tracking-[-0.02em] text-black">
          Verify new users with Plivo
        </h1>
        <p class="text-base sm:text-lg text-gray-600 mt-4 max-w-[540px] mx-auto lg:mx-0 leading-relaxed">
          Eliminate fake accounts and verify customers - anywhere, in real time, with a 95% conversion rate.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mt-8 justify-center lg:justify-start">
          <a
            href="/pricing"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium border border-gray-300 text-black rounded-md hover:bg-gray-50 transition-colors"
          >
            Get volume pricing
          </a>
          <a
            href="https://cx.plivo.com/pungis2"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-black text-white rounded-md hover:bg-gray-800 transition-colors"
          >
            Sign up for free
          </a>
        </div>
        <!-- Feature badges -->
        <div class="flex items-center justify-center lg:justify-start gap-6 mt-6">
          <span class="inline-flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-[#323dfe]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Instant Integration
          </span>
          <span class="inline-flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-[#323dfe]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Zero Compliance Hurdles
          </span>
        </div>
      </div>

      <!-- Right Content - OTP Verification Illustration -->
      <div class="order-2 lg:order-2">
        <VerifyHeroIllustration client:visible />
      </div>
    </div>
  </div>
</section>
