---
interface Props {
  currentPage?: string;
}

const { currentPage = "overview" } = Astro.props;

const navItems = [
  { id: "overview", label: "SMS Overview", href: "/sms/overview" },
  { id: "coverage", label: "SMS Coverage", href: "/sms/coverage" },
  { id: "verify-api", label: "Verify API", href: "/sms/verify-api" },
  { id: "rcs", label: "RCS", href: "/sms/rcs" },
  { id: "verify-pricing", label: "Verify Pricing", href: "/verify/pricing" },
  { id: "pricing", label: "SMS Pricing", href: "/sms/pricing" },
];
---

<div class="border-b border-gray-200 bg-white fixed top-[72px] left-0 right-0 z-40">
  <div class="mx-auto max-w-7xl px-4">
    <nav class="flex items-center justify-end gap-6 overflow-x-auto scrollbar-hide">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "py-2 text-[13px] font-medium whitespace-nowrap transition-colors border-b-2 -mb-px",
            currentPage === item.id
              ? "text-black border-black"
              : "text-gray-500 border-transparent hover:text-gray-900 hover:border-gray-300"
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</div>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
