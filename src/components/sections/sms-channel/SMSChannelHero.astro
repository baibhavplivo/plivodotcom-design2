---
// SMSChannelHero.astro - Side-by-side hero with SMS illustration
import SMSHeroIllustration from "./SMSHeroIllustration";
---

<section class="hero bg-white pt-[56px] sm:pt-[64px] md:pt-[72px] pb-8">
  <div class="container mx-auto max-w-7xl px-4">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 items-center">
      <!-- Left Content -->
      <div class="order-1 lg:order-1 max-w-[820px] text-center lg:text-left">
        <h1 class="font-sora text-[2rem] sm:text-[2.5rem] md:text-[3rem] font-normal leading-[1.1] tracking-[-0.02em] text-black">
          Compliant, reliable SMS for verification & customer engagement
        </h1>
        <p class="text-base sm:text-lg text-gray-600 mt-4 max-w-[540px] mx-auto lg:mx-0 leading-relaxed">
          Ensure secure logins with instant OTPs, deliver critical notifications & marketing campaigns to 190+ countries with enterprise-grade reliability and compliance.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mt-8 justify-center lg:justify-start">
          <a
            href="/pricing"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium border border-gray-300 text-black rounded-md hover:bg-gray-50 transition-colors"
          >
            Get volume pricing
          </a>
          <a
            href="https://cx.plivo.com/pungis2"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-black text-white rounded-md cta-hover-gradient transition-colors"
          >
            Sign up for free
          </a>
        </div>
      </div>

      <!-- Right Content - SMS Illustration -->
      <div class="order-2 lg:order-2">
        <SMSHeroIllustration client:visible />
      </div>
    </div>
  </div>
</section>
