---
import PlivoLayout from "@/layouts/PlivoLayout.astro";
import WhatsAppSubNav from "@/components/sections/whatsapp-channel/WhatsAppSubNav.astro";
import WhatsAppCallPricing from "@/components/sections/whatsapp-channel/WhatsAppCallPricing";
import WhatsAppPricingVolumeCTA from "@/components/sections/whatsapp-channel/WhatsAppPricingVolumeCTA";
import WhatsAppCallPricingFAQ from "@/components/sections/whatsapp-channel/WhatsAppCallPricingFAQ";
import { getWhatsAppCallPricingMeta } from "@/data/whatsapp-call-pricing";

const { title, description } = getWhatsAppCallPricingMeta();
---

<PlivoLayout title={title} description={description}>
  <!-- WhatsApp Sub Navigation -->
  <WhatsAppSubNav currentPage="call-pricing" />

  <!-- WhatsApp Call Pricing with Country Selection -->
  <WhatsAppCallPricing client:visible />

  <!-- Volume Pricing CTA -->
  <WhatsAppPricingVolumeCTA />

  <!-- Pricing FAQ -->
  <WhatsAppCallPricingFAQ />
</PlivoLayout>
