import VoiceSubNav from "@/components/sections/voice-channel/VoiceSubNav.astro";
import VoicePricingTabs from "@/components/sections/voice-channel/VoicePricingTabs";
import PreFooterCTA from "@/components/sections/voice-homepage/PreFooterCTA";
---

<PlivoLayout
