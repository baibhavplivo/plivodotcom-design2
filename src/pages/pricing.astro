---
import PlivoLayout from '@/layouts/PlivoLayout.astro';
import { PlivoPricing } from '@/components/sections/plivo-pricing';
import { PlivoPricingFAQ } from '@/components/sections/plivo-pricing-faq';
import PreFooterCTA from '@/components/sections/voice-homepage/PreFooterCTA';
---

<PlivoLayout title="Pricing" description="Simple and transparent pay-as-you-go pricing for Voice, SMS, WhatsApp, and AI Agents. Get $10 in free credits to start.">
    <PlivoPricing client:load />
    <PlivoPricingFAQ client:visible />
    <PreFooterCTA client:visible title="Go live in minutes" />
</PlivoLayout>
