---
import PlivoLayout from "@/layouts/PlivoLayout.astro";
import SIPTrunkingSubNav from "@/components/sections/voice-channel/SIPTrunkingSubNav.astro";
import SIPTrunkingCoverage from "@/components/sections/voice-channel/SIPTrunkingCoverage";
import PreFooterCTA from "@/components/sections/voice-homepage/PreFooterCTA";
import {
  SIP_COVERAGE_COUNTRIES,
  SIP_COVERAGE_COUNTRY_NAMES,
} from "@/data/sip-coverage-data";

export function getStaticPaths() {
  return SIP_COVERAGE_COUNTRIES.map(({ code }) => ({
    params: { country: code.toLowerCase() },
    props: { countryCode: code },
  }));
}

const { countryCode } = Astro.props;
const countryName = SIP_COVERAGE_COUNTRY_NAMES[countryCode] || countryCode;
---

<PlivoLayout
  title={`SIP Coverage - ${countryName}`}
  description={`Plivo SIP trunking coverage details for ${countryName}. Number type availability, country specs, and inbound and outbound calling rates.`}
>
  <SIPTrunkingSubNav currentPage="coverage" />
  <SIPTrunkingCoverage client:visible initialCountry={countryCode} />
  <PreFooterCTA
    client:visible
    title="It's easy to get started. Sign up for free."
    subtitle="Create your account and receive trial credits or get in touch with us."
  />
</PlivoLayout>
