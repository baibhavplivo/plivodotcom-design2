---
import PlivoLayout from "@/layouts/PlivoLayout.astro";
---

<PlivoLayout title="Something went wrong | Plivo" description="An unexpected error occurred. Please try again.">
  <section class="bg-background py-24 sm:py-32 lg:py-40">
    <div class="container mx-auto max-w-7xl px-4 text-center">
      <p class="text-[13px] font-semibold uppercase tracking-wider text-primary mb-4">500 error</p>
      <h1 class="font-sora text-[2rem] sm:text-[2.5rem] md:text-[3rem] font-normal leading-[1.1] tracking-[-0.02em] text-foreground mb-4">
        Something went wrong
      </h1>
      <p class="text-base sm:text-lg text-muted-foreground max-w-lg mx-auto mb-10">
        We're experiencing a temporary issue. Please try again in a moment, or contact us if the problem persists.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-foreground text-background rounded-md cta-hover-gradient transition-colors"
        >
          Back to home
        </a>
        <a
          href="https://status.plivo.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium border border-border-strong text-foreground rounded-md hover:bg-surface transition-colors"
        >
          Check platform status
        </a>
      </div>
    </div>
  </section>
</PlivoLayout>
