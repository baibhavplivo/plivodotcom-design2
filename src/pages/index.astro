---
import PlivoLayout from '@/layouts/PlivoLayout.astro';
import VoiceHero from '@/components/sections/voice-homepage/VoiceHero.astro';
import VoiceDemo from '@/components/sections/voice-homepage/VoiceDemo';
import ClientLogos from '@/components/sections/voice-homepage/ClientLogos.astro';
import AgentBuilder from '@/components/sections/voice-homepage/AgentBuilder';
import ImpactStats from '@/components/sections/voice-homepage/ImpactStats';
import WhyHumanLike from '@/components/sections/voice-homepage/WhyHumanLike';
import Compliance from '@/components/sections/voice-homepage/Compliance.astro';

import PreFooterCTA from '@/components/sections/voice-homepage/PreFooterCTA';
---

<PlivoLayout
  title="Plivo - Build Voice AI Agents That Sound Human"
  description="From no-code builders for teams to flexible APIs for developers, deploy voice agents that actually sound human."
>
  <!-- Hero Section -->
  <VoiceHero />

  <!-- Voice Demo with Wavy Background -->
  <VoiceDemo client:load />

  <!-- Client Logos Marquee -->
  <ClientLogos />

  <!-- Agent Builder Section -->
  <AgentBuilder client:visible />

  <!-- Impact Stats Section -->
  <ImpactStats client:visible />

  <!-- Why Human-Like Section -->
  <WhyHumanLike client:visible />

  <!-- Compliance Section -->
  <Compliance />

  <!-- Pre-Footer CTA -->
  <PreFooterCTA client:visible />
</PlivoLayout>
