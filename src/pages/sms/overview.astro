---
import PlivoLayout from "@/layouts/PlivoLayout.astro";
import SMSSubNav from "@/components/sections/sms-channel/SMSSubNav.astro";
import SMSChannelHero from "@/components/sections/sms-channel/SMSChannelHero.astro";
import ClientLogos from "@/components/sections/voice-homepage/ClientLogos.astro";
import SMSUseCases from "@/components/sections/sms-channel/SMSUseCases";
import SMSConnectivityGrid from "@/components/sections/sms-channel/SMSConnectivityGrid";
import SMSAIAgentsAccordion from "@/components/sections/sms-channel/SMSAIAgentsAccordion";
import SMSEngagementPlatform from "@/components/sections/sms-channel/SMSEngagementPlatform";
import SMSPreFooterCTA from "@/components/sections/sms-channel/SMSPreFooterCTA";
---

<PlivoLayout title="SMS API & Marketing Platform | Plivo" description="Send reliable SMS for OTP verification, alerts, and marketing campaigns to 190+ countries. Enterprise-grade delivery with built-in fraud prevention.">
  <!-- SMS Sub Navigation -->
  <SMSSubNav currentPage="overview" />

  <!-- Hero Section -->
  <SMSChannelHero />

  <!-- Client Logos Marquee -->
  <ClientLogos />

  <!-- SMS Use Cases Grid -->
  <SMSUseCases client:visible />

  <!-- SMS Connectivity Features - 6 Card Grid -->
  <SMSConnectivityGrid client:visible />

  <!-- SMS AI Agents Accordion -->
  <SMSAIAgentsAccordion client:visible />

  <!-- Complete SMS Engagement Platform -->
  <SMSEngagementPlatform client:visible />

  <!-- Pre-Footer CTA -->
  <SMSPreFooterCTA client:visible />
</PlivoLayout>
