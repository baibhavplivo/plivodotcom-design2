import SMSPricingPage from "@/components/sections/sms-channel/SMSPricingPage";
import PreFooterCTA from "@/components/sections/voice-homepage/PreFooterCTA";
---

<PlivoLayout
  title="SMS Messaging API Pricing"
  description="Get competitive pay-as-you-go SMS pricing, MMS pricing, and phone number rentals, with volume discounts available for committed spend."
>
