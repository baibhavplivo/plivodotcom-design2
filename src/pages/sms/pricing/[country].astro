---
import PlivoLayout from "@/layouts/PlivoLayout.astro";
import SMSSubNav from "@/components/sections/sms-channel/SMSSubNav.astro";
import SMSPricingTabs from "@/components/sections/sms-channel/SMSPricingTabs";
import SMSPreFooterCTA from "@/components/sections/sms-channel/SMSPreFooterCTA";
import { COUNTRY_NAMES } from "@/data/pricing-data";

export function getStaticPaths() {
  return Object.keys(COUNTRY_NAMES).map((code) => ({
    params: { country: code.toLowerCase() },
    props: { countryCode: code },
  }));
}

const { countryCode } = Astro.props;
const countryName = COUNTRY_NAMES[countryCode] || countryCode;
---

<PlivoLayout title={`SMS Pricing - ${countryName} | Plivo`} description={`Explore Plivo's SMS and RCS pricing for ${countryName}. View rates for SMS, MMS, phone number rental, and add-on services.`}>
  <SMSSubNav currentPage="pricing" />
  <SMSPricingTabs client:visible initialCountry={countryCode} />
  <SMSPreFooterCTA client:visible />
</PlivoLayout>
