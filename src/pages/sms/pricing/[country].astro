---
import PlivoLayout from "@/layouts/PlivoLayout.astro";
import SMSSubNav from "@/components/sections/sms-channel/SMSSubNav.astro";
import SMSPricingPage from "@/components/sections/sms-channel/SMSPricingPage";
import PreFooterCTA from "@/components/sections/voice-homepage/PreFooterCTA";
import {
  SMS_PRICING_COUNTRY_CODES,
  getSMSPricingMeta,
} from "@/data/sms-pricing-page";

export function getStaticPaths() {
  return SMS_PRICING_COUNTRY_CODES.map((code) => ({
    params: { country: code.toLowerCase() },
    props: { countryCode: code },
  }));
}

const { countryCode } = Astro.props;
const { title, description } = getSMSPricingMeta(countryCode);
---

<PlivoLayout title={title} description={description}>
  <SMSSubNav currentPage="pricing" />
  <SMSPricingPage client:load initialCountry={countryCode} />
  <PreFooterCTA client:visible title="It's easy to get started. Sign up for free." subtitle="Create your account and receive trial credits or get in touch with us." />
</PlivoLayout>
