---
import BaseHead from '@/components/BaseHead.astro';
import { Navbar1 } from '@/components/sections/navbar1';
import { PlivoFooter } from '@/components/sections/plivo-footer';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Plivo enables businesses to communicate with their customers through voice, messaging, and more with APIs that simplify cloud communications." } = Astro.props;
const isDev = import.meta.env.DEV;
const gtmContainerId = import.meta.env.PROD
  ? (import.meta.env.PUBLIC_GTM_CONTAINER_ID || "GTM-MXJNN5")
  : "";
const gtmAllowedHosts = (import.meta.env.PUBLIC_GTM_ALLOWED_HOSTS || "www.plivo.com")
  .split(",")
  .map((host) => host.trim())
  .filter(Boolean);
---

<html lang="en">
  <head>
    <BaseHead title={`${title} | Plivo`} description={description} />
    {isDev && (
      <script type="module" is:inline>
        import RefreshRuntime from "/@react-refresh";

        RefreshRuntime.injectIntoGlobalHook(window);
        window.$RefreshReg$ = () => {};
        window.$RefreshSig$ = () => (type) => type;
        window.__vite_plugin_react_preamble_installed__ = true;
      </script>
    )}
  </head>
  <body class="min-h-screen bg-white antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-md focus:bg-black focus:px-4 focus:py-2 focus:text-sm focus:text-white focus:outline-none">
      Skip to main content
    </a>
    <Navbar1 currentPage={Astro.url.pathname} client:load />
    <main id="main-content" class="flex flex-col bg-white pt-[72px]">
      <slot />
    </main>
    <PlivoFooter client:visible />

    <!-- Geo-gated CTA rewriting for .astro components -->
    <script is:inline>
    (function() {
      var CATEGORY_A = ["US","CA","IN","GB","AU","NZ","SG"];
      var CATEGORY_B = ["BR","AE","AR","DE","FR","NL","BE","IE","IT","IL","MY","ID","PT"];
      var SIGNUP_URL = "https://plivo.com/signup";
      var TRIAL_URL = "/request-trial/";
      var SALES_URL = "/contact/sales/";

      function getCategory(code) {
        if (!code) return "";
        code = code.toUpperCase();
        if (CATEGORY_A.indexOf(code) >= 0) return "A";
        if (CATEGORY_B.indexOf(code) >= 0) return "B";
        return "unsupported";
      }

      function updateCTAs() {
        var country = "";
        try { country = sessionStorage.getItem("plivo_geo_country") || ""; } catch(e) {}
        if (!country) return false;

        var cat = getCategory(country);
        var links = document.querySelectorAll('[data-geo-cta="signup"]');
        for (var i = 0; i < links.length; i++) {
          var el = links[i];
          if (cat === "A") {
            el.setAttribute("href", SIGNUP_URL);
          } else if (cat === "B") {
            el.setAttribute("href", TRIAL_URL);
            el.removeAttribute("target");
            el.removeAttribute("rel");
            var text = (el.textContent || "").trim().toLowerCase();
            if (text === "sign up for free" || text === "start for free" || text === "sign up now" || text === "get started" || text === "get access") {
              el.textContent = "Request a trial";
            }
          } else {
            el.setAttribute("href", TRIAL_URL);
            el.removeAttribute("target");
            el.removeAttribute("rel");
            var text2 = (el.textContent || "").trim().toLowerCase();
            if (text2 === "sign up for free" || text2 === "start for free" || text2 === "sign up now" || text2 === "get started" || text2 === "get access") {
              el.textContent = "Request a trial";
            }
          }
        }
        return true;
      }

      // Try immediately
      if (!updateCTAs()) {
        // Poll for geo data (up to 4 seconds)
        var attempts = 0;
        var poll = setInterval(function() {
          attempts++;
          if (updateCTAs() || attempts > 40) {
            clearInterval(poll);
          }
        }, 100);
      }

      // Handle Astro page transitions
      document.addEventListener("astro:after-swap", function() {
        setTimeout(updateCTAs, 50);
      });
    })();
    </script>

    <!-- Cookie consent banner + analytics loader -->
    <script
      is:inline
      define:vars={{ gtmContainerId, gtmAllowedHosts }}
    >
    (function() {
      var consent = null;
      try { consent = localStorage.getItem("plivo_cookie_consent"); } catch(e) {}

      function loadGTM() {
        if (!gtmContainerId || !Array.isArray(gtmAllowedHosts)) return;
        if (gtmAllowedHosts.indexOf(window.location.hostname) === -1) return;
        if (window.__plivoGtmLoaded || document.getElementById("plivo-gtm-script")) return;

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          "gtm.start": new Date().getTime(),
          event: "gtm.js"
        });

        var gtmScript = document.createElement("script");
        gtmScript.id = "plivo-gtm-script";
        gtmScript.async = true;
        gtmScript.src = "https://www.googletagmanager.com/gtm.js?id=" + encodeURIComponent(gtmContainerId);
        document.head.appendChild(gtmScript);
        window.__plivoGtmLoaded = true;
      }

      function loadAnalytics() {
        // HubSpot tracking (portal 20451141)
        if (!document.getElementById("hs-script-loader")) {
          var hs = document.createElement("script");
          hs.id = "hs-script-loader";
          hs.async = true;
          hs.defer = true;
          hs.src = "//js.hs-scripts.com/20451141.js";
          document.body.appendChild(hs);
        }

        loadGTM();
      }

      if (consent === "accepted") {
        loadAnalytics();
        return;
      }
      if (consent === "rejected") return;

      // Show consent banner
      var banner = document.createElement("div");
      banner.id = "cookie-consent-banner";
      banner.style.cssText = "position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#fff;border-top:1px solid #e5e7eb;box-shadow:0 -2px 8px rgba(0,0,0,0.08);padding:14px 20px;display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;font-family:Inter,sans-serif;font-size:13px;color:#374151;";
      banner.innerHTML = '<span>We use cookies to improve your experience and for analytics. </span><button id="cc-accept" style="background:#000;color:#fff;border:none;border-radius:6px;padding:7px 16px;font-size:13px;font-weight:500;cursor:pointer;">Accept</button><button id="cc-reject" style="background:transparent;color:#374151;border:1px solid #d1d5db;border-radius:6px;padding:7px 16px;font-size:13px;font-weight:500;cursor:pointer;">Reject</button>';
      document.body.appendChild(banner);

      document.getElementById("cc-accept").addEventListener("click", function() {
        try { localStorage.setItem("plivo_cookie_consent", "accepted"); } catch(e) {}
        banner.remove();
        loadAnalytics();
      });
      document.getElementById("cc-reject").addEventListener("click", function() {
        try { localStorage.setItem("plivo_cookie_consent", "rejected"); } catch(e) {}
        banner.remove();
      });
    })();
    </script>
  </body>
</html>
