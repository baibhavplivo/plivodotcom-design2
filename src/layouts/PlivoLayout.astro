---
import BaseHead from '@/components/BaseHead.astro';
import { Navbar1 } from '@/components/sections/navbar1';
import { PlivoFooter } from '@/components/sections/plivo-footer';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Plivo enables businesses to communicate with their customers through voice, messaging, and more with APIs that simplify cloud communications." } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={`${title} | Plivo`} description={description} />
  </head>
  <body class="min-h-screen bg-white antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-md focus:bg-black focus:px-4 focus:py-2 focus:text-sm focus:text-white focus:outline-none">
      Skip to main content
    </a>
    <Navbar1 currentPage={Astro.url.pathname} client:load />
    <main id="main-content" class="flex flex-col bg-white pt-[72px]">
      <slot />
    </main>
    <PlivoFooter client:visible />
  </body>
</html>
