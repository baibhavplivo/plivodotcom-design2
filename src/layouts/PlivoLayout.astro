---
import BaseHead from '@/components/BaseHead.astro';
import CookieConsentManager from '@/components/CookieConsentManager.astro';
import { Navbar1 } from '@/components/sections/navbar1';
import { PlivoFooter } from '@/components/sections/plivo-footer';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
}

const { title, description = "Plivo enables businesses to communicate with their customers through voice, messaging, and more with APIs that simplify cloud communications.", image, ogType } = Astro.props;
const isDev = import.meta.env.DEV;
const gtmContainerId = import.meta.env.PROD
  ? (import.meta.env.PUBLIC_GTM_CONTAINER_ID || "GTM-MXJNN5")
  : "";
const gtmAllowedHosts = (import.meta.env.PUBLIC_GTM_ALLOWED_HOSTS || "www.plivo.com")
  .split(",")
  .map((host) => host.trim())
  .filter(Boolean);
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY || "phc_L7KN2rQgiafKZeW8nz4orh2cGcBxn8CJjsPfpkDEBQj";
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || "https://us.i.posthog.com";
---

<html lang="en">
  <head>
    <BaseHead title={`${title} | Plivo`} description={description} image={image} ogType={ogType} />
    <slot name="head" />
    {isDev && (
      <script type="module" is:inline>
        import RefreshRuntime from "/@react-refresh";

        RefreshRuntime.injectIntoGlobalHook(window);
        window.$RefreshReg$ = () => {};
        window.$RefreshSig$ = () => (type) => type;
        window.__vite_plugin_react_preamble_installed__ = true;
      </script>
    )}
  </head>
  <body class="min-h-screen bg-white antialiased">
    {/* Google Tag Manager (noscript) - only in production */}
    {gtmContainerId && (
      <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmContainerId}`} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    )}
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-md focus:bg-black focus:px-4 focus:py-2 focus:text-sm focus:text-white focus:outline-none">
      Skip to main content
    </a>
    <Navbar1 currentPage={Astro.url.pathname} client:load />
    <main id="main-content" class="flex flex-col bg-white pt-[72px]">
      <slot />
    </main>
    <PlivoFooter client:visible />

    <!-- Geo-gated CTA rewriting for .astro components -->
    <script is:inline>
    (function() {
      var SUPPORTED = ["US","CA","BR","AR","GB","DE","FR","NL","BE","IE","ES","PT","IT","IL","AE","SA","QA","BH","IN","SG","MY","ID","VN","AU","NZ"];
      var SIGNUP_URL = "https://plivo.com/signup";
      var TRIAL_URL = "/request-trial/";

      function updateCTAs() {
        var country = "";
        try { country = sessionStorage.getItem("plivo_geo_country") || ""; } catch(e) {}
        if (!country) return false;

        var isSupported = SUPPORTED.indexOf(country.toUpperCase()) >= 0;
        var links = document.querySelectorAll('[data-geo-cta="signup"]');
        for (var i = 0; i < links.length; i++) {
          var el = links[i];
          if (isSupported) {
            el.setAttribute("href", SIGNUP_URL);
          } else {
            el.setAttribute("href", TRIAL_URL);
            el.removeAttribute("target");
            el.removeAttribute("rel");
            var text = (el.textContent || "").trim().toLowerCase();
            if (text === "sign up for free" || text === "start for free" || text === "sign up now" || text === "get started" || text === "get access") {
              el.textContent = "Request a trial";
            }
          }
        }
        return true;
      }

      // Try immediately
      if (!updateCTAs()) {
        // Poll for geo data (up to 4 seconds)
        var attempts = 0;
        var poll = setInterval(function() {
          attempts++;
          if (updateCTAs() || attempts > 40) {
            clearInterval(poll);
          }
        }, 100);
      }

      // Handle Astro page transitions
      document.addEventListener("astro:after-swap", function() {
        setTimeout(updateCTAs, 50);
      });
    })();
    </script>

    <CookieConsentManager
      gtmContainerId={gtmContainerId}
      gtmAllowedHosts={gtmAllowedHosts}
      posthogKey={posthogKey}
      posthogHost={posthogHost}
    />
  </body>
</html>
